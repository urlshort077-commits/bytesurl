{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ES2023",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "rootDir": "./",
        "baseUrl": ".",
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "src/**/*",
        "generated/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}