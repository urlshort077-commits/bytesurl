model Payments {
    id              String   @id @default(cuid())
    userId          String
    stripeSessionId String
    stripePaymentId String   @unique
    amount          Float
    currency        String
    plan            Plan
    createdAt       DateTime @default(now())

    user         User           @relation(fields: [userId], references: [id], onDelete: Restrict)
    subscription Subscriptions?

    @@index([userId])
    @@index([plan])
    @@map("payments")
}
