model User {
    id          String     @id @default(cuid())
    firebaseUid String     @unique
    email       String     @unique
    name        String
    avatarUrl   String?
    role        Role       @default(USER)
    status      UserStatus @default(ACTIVE)
    createdAt   DateTime   @default(now())
    updatedAt   DateTime?  @updatedAt

    urls         Urls[]
    payments     Payments[]
    subscription Subscriptions?

    @@index([email])
    @@index([firebaseUid])
    @@index([role])
    @@index([status])
    @@map("users")
}
